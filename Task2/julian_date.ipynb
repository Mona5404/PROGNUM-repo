   "source": [
    "#Input a date\n",
    "Y = float(input(\"Year:\"))\n",
    "M = float(input(\"Month:\"))\n",
    "D = float(input(\"Day:\"))\n",
    "\n",
    "#Julian date formula:\n",
    "JD = 367*Y -7*(Y+(M+9)/12)/4 - 3*((Y+(M-9)/7)/100 + 1)/4 + (275*M)/9 + D + 1721029-0.5\n",
    "\n",
    "print(f\"The days elapsed is {JD}\")\n"
   ]
