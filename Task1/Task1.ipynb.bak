   "source": [
    "#Q1.5\n",
    "from scipy.constants import h,c\n",
    "#Importing these constants for ease of use\n",
    "f=(2.42e28)\n",
    "wl=c/f\n",
    "#wl is in this case wavelength\n",
    "E=h*(c/wl)\n",
    "print(E)"
   ]
  },
